{
  "name": "license-report-check",
  "version": "0.1.2",
  "description": "Validate the types of the licenses of the dependencies of a project",
  "main": "index.js",
  "bin": {
    "license-report-check": "./index.js"
  },
  "type": "module",
  "files": [
    "index.js",
    "lib/",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BePo65/license-report-check.git"
  },
  "bugs": "https://github.com/BePo65/license-report-check/issues",
  "scripts": {
    "lint": "npm exec biome check .",
    "lint:fix": "npm exec biome check --write .",
    "test": "node --test --test-reporter=spec",
    "lint-commits": "commitlint --from e86b01e0b9f467 --to HEAD --verbose",
    "init-changelog": "commit-and-tag-version -i CHANGELOG.md --same-file --prerelease pre --first-release",
    "release": "commit-and-tag-version -i CHANGELOG.md --same-file",
    "prepare": "husky"
  },
  "keywords": [
    "license",
    "cli",
    "check"
  ],
  "author": "BePo65",
  "license": "MIT",
  "dependencies": {
    "easy-table": "^1.2.0",
    "rc": "^1.2.8",
    "stream-json": "^1.9.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-angular": "^20.4.3",
    "commit-and-tag-version": "^12.6.1",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "sinon": "^21.0.2",
    "streamtest": "^3.0.1"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "**/*": "npx @biomejs/biome check --write ."
  },
  "commit-and-tag-version": {
    "packageFiles": [
      {
        "filename": "package.json",
        "type": "json"
      }
    ],
    "bumpFiles": [
      {
        "filename": "package.json",
        "type": "json"
      },
      {
        "filename": "package-lock.json",
        "type": "json"
      },
      {
        "filename": "README.md",
        "updater": "tools/npm-scripts/readme-updater.cjs"
      }
    ]
  }
}
