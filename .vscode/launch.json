  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch unknown.test",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**/*.js"],
      "program": "${workspaceFolder}\\index.js",
      "args": ["--source", "${workspaceFolder}/test/fixture/package.unknown.test.json"]
    },
    {
      "name": "Launch forbidden",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**/*.js"],
      "program": "${workspaceFolder}\\index.js",
      "args": [
        "--source",
        "${workspaceFolder}/test/fixture/package.unknown.test.json",
        "--forbidden",
        "Apache-2.0"
      ]
    },
    {
      "name": "Launch allowed + forbidden",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**/*.js"],
      "program": "${workspaceFolder}\\index.js",
      "args": [
        "--source",
        "${workspaceFolder}/test/fixture/package.unknown.test.json",
        "--allowed",
        "MIT",
        "--forbidden",
        "Apache-2.0"
      ]
    },
    {
      "name": "Launch allowed as csv",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**/*.js"],
      "program": "${workspaceFolder}\\index.js",
      "args": [
        "--source",
        "${workspaceFolder}/test/fixture/package.unknown.test.json",
        "--allowed",
        "MIT",
        "--output",
        "csv"
      ]
    },
    {
      "name": "Launch allowed as csv with headers",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**/*.js"],
      "program": "${workspaceFolder}\\index.js",
      "args": [
        "--source",
        "${workspaceFolder}/test/fixture/package.unknown.test.json",
        "--allowed",
        "MIT",
        "--output",
        "csv",
        "--csvHeaders"
      ]
    },
    {
      "name": "Launch allowed table",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**/*.js"],
      "program": "${workspaceFolder}\\index.js",
      "args": [
        "--source",
        "${workspaceFolder}/test/fixture/package.unknown.test.json",
        "--allowed",
        "MIT",
        "--forbidden",
        "Apache-2.0",
        "--output",
        "table"
      ]
    }
  ]
}
